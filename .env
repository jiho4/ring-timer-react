# Ring Timer Configuration
# Note: Changes to this file require restart of the dev server

# Warning threshold: background color starts changing when remaining time <= this value (in seconds)
REACT_APP_WARNING_THRESHOLD_SECONDS=30

# Default timer interval (in seconds)
REACT_APP_DEFAULT_INTERVAL_SECONDS=290

# Grace period (in seconds): resets within this window after start won't increment loop count
REACT_APP_LOOP_COUNT_GRACE_PERIOD_SECONDS=5

# Color Configuration
# Background color
REACT_APP_COLOR_BACKGROUND=#282c34

# Warning color at 0 seconds (red)
REACT_APP_COLOR_ALERT=#cb3e3e

# Transition color range (from default to warning)
# Start color RGB values (default dark background)
REACT_APP_COLOR_TRANSITION_START_R=40
REACT_APP_COLOR_TRANSITION_START_G=44
REACT_APP_COLOR_TRANSITION_START_B=52

# End color RGB values (bright yellow/orange warning)
REACT_APP_COLOR_TRANSITION_END_R=200
REACT_APP_COLOR_TRANSITION_END_G=180
REACT_APP_COLOR_TRANSITION_END_B=60
