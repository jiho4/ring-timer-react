# Ring Timer Test Configuration
# These values are used during testing to ensure tests are independent from production config

# Warning threshold for tests
REACT_APP_WARNING_THRESHOLD_SECONDS=10

# Default timer interval for tests
REACT_APP_DEFAULT_INTERVAL_SECONDS=30

# Grace period for tests
REACT_APP_LOOP_COUNT_GRACE_PERIOD_SECONDS=5

# Color Configuration for tests
# Default background color (test dark)
REACT_APP_COLOR_BACKGROUND=#111111

# Warning color at 0 seconds (test red)
REACT_APP_COLOR_ALERT=#ff0000

# Transition color range for tests
# Start color RGB values
REACT_APP_COLOR_TRANSITION_START_R=17
REACT_APP_COLOR_TRANSITION_START_G=17
REACT_APP_COLOR_TRANSITION_START_B=17

# End color RGB values
REACT_APP_COLOR_TRANSITION_END_R=255
REACT_APP_COLOR_TRANSITION_END_G=200
REACT_APP_COLOR_TRANSITION_END_B=0
